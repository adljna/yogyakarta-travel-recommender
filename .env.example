# NEO4J Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password_here

# API Keys
GOOGLE_PLACES_API_KEY=your_google_places_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
WIKIDATA_SPARQL_ENDPOINT=https://query.wikidata.org/sparql

# Region Configuration (MVP)
REGION=yogyakarta
REGION_WIKIDATA_ID=Q3727

# Data Settings
RAW_DATA_PATH=data/raw
PROCESSED_DATA_PATH=data/processed
NEO4J_IMPORT_PATH=data/neo4j_imports

# LLM Settings
LLM_MODEL=claude-3-5-sonnet-20241022
LLM_MAX_TOKENS=4000
TEMPERATURE=0.7

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Cache Settings (optional)
REDIS_URL=redis://localhost:6379
CACHE_TTL_HOURS=24

# Data Collection
RATE_LIMIT_GOOGLE_PLACES=100
BATCH_SIZE_WIKIDATA=1000
GOOGLE_PLACES_RETRY_MAX=3
